---
// Datos simulados de emprendedores
const emprendedoresSimulados = [
  {
    id: "EMP-001",
    nombre: "Manjar Artesanal Los Andes",
    email: "manjar.andes@paypal.com",
    descripcion: "Confecciones artesanales con técnicas ancestrales",
    imagen: "🏺",
    donacionesRecibidas: 1250
  },
  {
    id: "EMP-002",
    nombre: "Tejidos Wayna",
    email: "tejidos.wayna@paypal.com",
    descripcion: "Textiles tradicionales hechos a mano",
    imagen: "🧵",
    donacionesRecibidas: 890
  },
  {
    id: "EMP-003",
    nombre: "Cerámica Andina",
    email: "ceramica.andina@paypal.com",
    descripcion: "Piezas de cerámica artesanal autóctona",
    imagen: "🎨",
    donacionesRecibidas: 2100
  }
];

// Datos para el panel del emprendedor (por defecto el primero)
const emprendedorActual = emprendedoresSimulados[0];

const montos = [5, 10, 20, 50, 100, 500];
---

<div class="paypal-container bg-gradient-to-br from-blue-50 to-teal-50 rounded-lg shadow-2xl overflow-hidden border border-gray-200">
  
  <!-- Panel del Emprendedor -->
  <div class="bg-white p-8 border-b border-gray-200">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-3xl font-bold text-gray-800 mb-2 flex items-center gap-2">
        <span class="text-4xl">{emprendedorActual.imagen}</span>
        Registra tu Emprendimiento
      </h2>
      <p class="text-gray-600 mb-6 text-base">Ingresa tus datos para habilitar tu perfil y recibir donaciones directamente a tu PayPal</p>
      
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-bold text-gray-700 mb-2">Nombre Completo / Emprendimiento:</label>
          <input 
            type="text" 
            id="nombre-emprendedor" 
            placeholder="Ej. Juan Pérez o Manjar Artesanal" 
            value={emprendedorActual.nombre}
            class="w-full border-2 border-gray-300 p-3 rounded-lg mb-1 text-base focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition"
          >
          <p class="text-xs text-gray-500">{emprendedorActual.descripcion}</p>
        </div>
        
        <div>
          <label class="block text-sm font-bold text-gray-700 mb-2">Correo Electrónico de PayPal:</label>
          <input 
            type="email" 
            id="email-emprendedor" 
            placeholder="correo.emprendedor@paypal.com" 
            value={emprendedorActual.email}
            class="w-full border-2 border-gray-300 p-3 rounded-lg text-base focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition"
          >
        </div>
      </div>
      
      <button 
        onclick="guardarDatosEmprendedor()" 
        class="w-full mt-6 bg-gradient-to-r from-blue-500 to-blue-600 text-white py-3 rounded-lg font-bold hover:from-blue-600 hover:to-blue-700 transition transform hover:scale-105 shadow-lg"
      >
        💾 Guardar mis datos de perfil
      </button>
      <p id="mensaje-exito" class="text-green-600 text-sm font-bold mt-3 hidden bg-green-50 p-3 rounded-lg border border-green-200">
        ✓ ¡Datos guardados con éxito! Tu perfil está activo.
      </p>
    </div>
  </div>

  <!-- Perfil Público del Emprendedor -->
  <div class="bg-gradient-to-r from-teal-50 to-blue-50 p-8 text-center border-b border-gray-200">
    <div class="max-w-2xl mx-auto">
      <h3 class="text-2xl font-bold text-gray-800 mb-6">Perfil Público del Emprendedor</h3>
      
      <div class="grid grid-cols-3 gap-4 mb-6 text-center">
        <div class="bg-white rounded-lg p-4 shadow">
          <div class="text-3xl mb-2">💰</div>
          <div class="text-2xl font-bold text-teal-600">${emprendedorActual.donacionesRecibidas}</div>
          <div class="text-xs text-gray-600">Recaudado</div>
        </div>
        <div class="bg-white rounded-lg p-4 shadow">
          <div class="text-3xl mb-2">👥</div>
          <div class="text-2xl font-bold text-teal-600">24</div>
          <div class="text-xs text-gray-600">Apoyo</div>
        </div>
        <div class="bg-white rounded-lg p-4 shadow">
          <div class="text-3xl mb-2">⭐</div>
          <div class="text-2xl font-bold text-teal-600">4.8</div>
          <div class="text-xs text-gray-600">Calificación</div>
        </div>
      </div>
      
      <button 
        onclick="abrirModalPago()" 
        class="bg-gradient-to-r from-teal-500 to-teal-600 text-white px-8 py-3 rounded-full font-bold shadow-lg hover:from-teal-600 hover:to-teal-700 transition transform hover:scale-105 inline-block"
      >
        💝 Apoyar a este Emprendedor
      </button>
    </div>
  </div>

  <!-- Modal de Pago -->
  <div id="modal-pago" class="hidden fixed inset-0 bg-black/50 flex justify-center items-center z-50 p-4">
    <div class="bg-white w-full max-w-lg rounded-xl shadow-2xl overflow-hidden transform transition">
      <!-- Header del Modal -->
      <div class="bg-gradient-to-r from-blue-500 to-teal-500 py-6 text-center">
        <h2 class="text-white text-3xl font-bold tracking-wide">✨ Enviar Apoyo</h2>
      </div>

      <div class="p-8">
        <!-- Info del Emprendedor -->
        <div class="bg-blue-50 p-6 mb-6 border-2 border-blue-200 rounded-lg">
          <div class="text-center mb-4 text-xs uppercase font-bold tracking-wider text-blue-900/70">
            Estás apoyando a:
          </div>
          <div class="flex flex-col items-center justify-center text-blue-900 text-center">
            <div class="text-3xl mb-3">{emprendedorActual.imagen}</div>
            <div id="modal-ver-nombre" class="text-2xl font-bold leading-tight mb-3">{emprendedorActual.nombre}</div>
            
            <div class="w-full border-t border-blue-300 my-3"></div>
            
            <div class="flex justify-between w-full text-sm opacity-90 gap-4">
              <div class="flex-1">
                <span class="font-bold">ID Emprendedor:</span><br>
                <span id="modal-ver-id" class="font-mono text-blue-700">{emprendedorActual.id}</span>
              </div>
              <div class="flex-1">
                <span class="font-bold">Cuenta de Destino:</span><br>
                <span id="modal-ver-email" class="break-all text-blue-700 text-xs">{emprendedorActual.email}</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Selector de Montos -->
        <div class="mb-8">
          <p class="text-sm font-bold text-gray-800 mb-4">Selecciona el Monto de tu Donación:</p>
          <div class="grid grid-cols-3 gap-3" id="contenedor-montos">
            {montos.map((monto) => (
              <button 
                class={`monto-btn py-3 px-2 text-base font-bold rounded-lg border-2 transition transform hover:scale-105 ${
                  monto === 20 
                    ? 'bg-teal-500 text-white border-teal-500' 
                    : 'bg-white text-blue-600 border-blue-300 hover:border-blue-500'
                }`}
                data-monto={monto}
              >
                ${monto}
              </button>
            ))}
          </div>
        </div>

        <!-- Contenedor de PayPal -->
        <div id="paypal-button-container" class="w-full mb-4"></div>
        
        <!-- Botón Cancelar -->
        <div class="text-center">
          <button 
            onclick="cerrarModalPago()" 
            class="text-sm text-gray-500 hover:text-gray-700 underline font-medium transition"
          >
            ✕ Cancelar
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  let montoActual = "20.00";
  
  let datosEmprendedor = {
    nombre: "",
    email: "",
    idSistema: ""
  };

  window.guardarDatosEmprendedor = function() {
    const txtNombre = document.getElementById('nombre-emprendedor')?.value.trim() || "";
    const txtEmail = document.getElementById('email-emprendedor')?.value.trim() || "";
    
    if(txtNombre === "" || !txtEmail.includes("@")) {
      alert("⚠️ Por favor, introduce un nombre y un correo electrónico válido.");
      return;
    }

    datosEmprendedor.nombre = txtNombre;
    datosEmprendedor.email = txtEmail;
    datosEmprendedor.idSistema = "EMP-" + Math.floor(100000 + Math.random() * 900000);

    document.getElementById('modal-ver-nombre').innerText = datosEmprendedor.nombre;
    document.getElementById('modal-ver-email').innerText = datosEmprendedor.email;
    document.getElementById('modal-ver-id').innerText = datosEmprendedor.idSistema;

    document.getElementById('mensaje-exito').classList.remove('hidden');
  };

  window.abrirModalPago = function() {
    if(datosEmprendedor.email === "") {
      alert("⚠️ Primero debes registrar tus datos en el panel superior.");
      return;
    }
    const modal = document.getElementById('modal-pago');
    if(modal) {
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }
  };

  window.cerrarModalPago = function() {
    const modal = document.getElementById('modal-pago');
    if(modal) {
      modal.classList.add('hidden');
      document.body.style.overflow = 'auto';
    }
  };

  // Lógica de selección de montos
  const botonesMonto = document.querySelectorAll('.monto-btn');
  botonesMonto.forEach((boton) => {
    boton.addEventListener('click', function(e) {
      const btn = e.target;
      if(btn && btn instanceof HTMLElement) {
        botonesMonto.forEach(b => {
          b.className = "monto-btn py-3 px-2 text-base font-bold rounded-lg border-2 transition transform hover:scale-105 bg-white text-blue-600 border-blue-300 hover:border-blue-500";
        });
        btn.className = "monto-btn py-3 px-2 text-base font-bold rounded-lg border-2 transition transform hover:scale-105 bg-teal-500 text-white border-teal-500";
        const montoValue = btn.getAttribute('data-monto');
        if(montoValue) {
          montoActual = montoValue + ".00";
        }
      }
    });
  });

  // Cargar SDK de PayPal dinámicamente
  const scriptPayPal = document.createElement('script');
  scriptPayPal.src = "https://www.paypal.com/sdk/js?client-id=AYaQ6yzDA23Y8uGbdm-3eV-BBgPRqbrLDOdh7FG_BBJpLyaZdePr-f50oOXcGcRqEXdgMG-4cicKfcFC&currency=USD";

  scriptPayPal.onload = function() {
    if(window.paypal && window.paypal.Buttons) {
      window.paypal.Buttons({
        style: { 
          layout: 'vertical', 
          color: 'gold', 
          shape: 'rect', 
          label: 'paypal', 
          height: 45
        },
        createOrder: function(data, actions) {
          return actions.order.create({
            purchase_units: [{
              amount: { value: montoActual },
              payee: { 
                email_address: datosEmprendedor.email
              },
              description: "Apoyo a Emprendedor - Manq'a y Wayna"
            }]
          });
        },
        onApprove: function(data, actions) {
          return actions.order.capture().then(function(orderData) {
            alert('✅ ¡Donación procesada con éxito!\n\nHas enviado $' + montoActual + ' USD directo a:\n' + datosEmprendedor.nombre);
            window.cerrarModalPago();
          });
        },
        onError: function(err) {
          console.error(err);
          alert("❌ Error en el pago.\nAsegúrate de que el correo de destino sea válido.");
        }
      }).render('#paypal-button-container');
    }
  };

  document.head.appendChild(scriptPayPal);

  // Cerrar modal con Escape
  document.addEventListener('keydown', function(event) {
    if(event.key === 'Escape') {
      window.cerrarModalPago();
    }
  });
</script>

<style scoped>
  .paypal-container {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  }

  input::-webkit-outer-spin-button,
  input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  #modal-pago {
    backdrop-filter: blur(4px);
  }

  #modal-pago:not(.hidden) {
    animation: fadeIn 0.3s ease-in-out;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .monto-btn {
    transition: all 0.3s ease;
  }

  .monto-btn:active {
    transform: scale(0.95);
  }
</style>
