---
/**
 * Icon Component — Sistema de íconos SVG profesional para Wayna Manq'a
 * Estilo: Línea fina (stroke-based), 24x24 viewBox, consistente
 * Inspirado en Lucide Icons / Heroicons
 */
interface Props {
  name: string;
  size?: number;
  class?: string;
  strokeWidth?: number;
}

const { name, size = 24, class: className = '', strokeWidth = 1.75 } = Astro.props;
---

<svg
