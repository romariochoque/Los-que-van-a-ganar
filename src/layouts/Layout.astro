---
const { title = "Wayna Manq'a" } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">

<head>

  <meta charset="UTF-8" />
  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"/>
  <title>{title}</title>
  <link
    rel="preconnect"
    href="https://fonts.googleapis.com">

  <link
    rel="preconnect"
    href="https://fonts.gstatic.com"
    crossorigin>

  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
    rel="stylesheet">

  <style>

    :root{

      --bg:#050816;
      --card:#0f172a;
      --card2:#111827;
      --text:#ffffff;
      --gray:#94a3b8;
      --green:#22c55e;
      --green2:#16a34a;
      --border:rgba(255,255,255,.08);

    }

    body.light{

      --bg:#f3f4f6;
      --card:#ffffff;
      --card2:#e5e7eb;
      --text:#031742;
      --gray:#4b5563;
      --border:rgba(0,0,0,.08);

    }

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    html{
      scroll-behavior:smooth;
    }

    body{

      font-family:'Inter',sans-serif;

      background:var(--bg);

      color:var(--text);

      overflow-x:hidden;

      transition:.4s;

    }
 

    .sidebar{

      position:fixed;

      top:0;
      left:0;

      width:270px;
      height:100vh;

      background:var(--card);

      border-right:1px solid var(--border);

      padding:30px 20px;

      z-index:999;

      overflow:auto;

      transition:.4s;

    }

    .logo{

      display:flex;
      align-items:center;
      gap:12px;

      margin-bottom:40px;

    }

    .circle{

      width:18px;
      height:18px;

      border-radius:50%;

      background:var(--green);

    }

    .logo h2{
      font-size:1.2rem;
    }

    .menu{

      display:flex;

      flex-direction:column;

      gap:14px;

    }

    .menu a{

      text-decoration:none;

      color:var(--gray);

      padding:14px 18px;

      border-radius:14px;

      transition:.3s;

      font-weight:600;

    }

    .menu a:hover{

      background:rgba(34,197,94,.12);

      color:#86efac;

      transform:translateX(6px);

    }


    .topbar{

      position:fixed;

      left:270px;
      right:0;
      top:0;

      height:80px;

      background:rgba(5,8,22,.7);

      backdrop-filter:blur(14px);

      border-bottom:1px solid var(--border);

      display:flex;

      align-items:center;
      justify-content:space-between;

      padding:0 30px;

      z-index:998;

    }

    body.light .topbar{
      background:rgba(255,255,255,.7);
    }

    .actions{

      display:flex;
      align-items:center;
      gap:14px;

    }

    .search{

      width:321px;

      background:var(--card2);

      border:1px solid var(--border);

      border-radius:14px;

      padding:12px 18px;

      color:var(--text);

      outline:none;

      font-size:1rem;

    }

    .search::placeholder{
      color:var(--gray);
    }

    .toggle-btn{

      border:none;

      background:linear-gradient(
        135deg,
        var(--green),
        var(--green2)
      );

      color:white;

      padding:12px 18px;

      border-radius:14px;

      cursor:pointer;

      font-weight:700;

      transition:.3s;

    }

    .toggle-btn:hover{
      transform:translateY(-2px);
    }

     
    .main-content{

      margin-left:270px;

      padding-top:100px;

      min-height:100vh;

      padding-bottom:60px;

    }
 

    ::-webkit-scrollbar{
      width:10px;
    }

    ::-webkit-scrollbar-track{
      background:#07111f;
    }

    ::-webkit-scrollbar-thumb{
      background:#22c55e;
      border-radius:20px;
    }
 
    .mobile-menu{
      display:none;
    }

    @media(max-width:900px){

      .sidebar{
        left:-300px;
      }

      .sidebar.active{
        left:0;
      }

      .topbar{
        left:0;
      }

      .main-content{
        margin-left:0;
      }

      .mobile-menu{
        display:block;
      }

      .search{
        width:180px;
      }

    }

  </style>

</head>

<body>

   

  <aside
    class="sidebar"
    id="sidebar"
  >

    <div class="logo">

      <div class="circle"></div>

      <h2>WAYNA MANQ'A</h2>

    </div>

    <div class="menu">

      <a href="#historias">
        Historias
      </a>

      <a href="#comentarios">
        Comentarios
      </a>

      <a href="#donaciones">
        Donaciones
      </a>

      <a href="#impacto">
         Impacto
      </a>
      <a
  href="javascript:void(0)"
  onclick="toggleTheme()"
>
Tema
</a>
    </div>

  </aside> 

  <header class="topbar">

    <div class="actions">

      <button
        class="toggle-btn mobile-menu"
        onclick="toggleSidebar()"
      >
        ☰
      </button>

      <input
        type="text"
        class="search"
        id="searchInput"
        placeholder="Buscar historias..."
      >

    </div>

    <button
      class="toggle-btn"
      onclick="toggleTheme()"
    >
      🌙 Dark / Light
    </button>

  </header>
 

  <main class="main-content">

    <slot />

  </main>
 
  <script is:inline>

    window.toggleTheme = function(){

      document.body.classList.toggle("light");

    };

    window.toggleSidebar = function(){

      document
      .getElementById("sidebar")
      .classList
      .toggle("active");

    };

  </script>

</body>
</html>